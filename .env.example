# Gemini API Key (obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configurations (defaults for Docker Compose setup)
DATABASE_URL=postgresql://netshield_user:netshield_pass@db:5432/netshield_db
POSTGRES_USER=netshield_user
POSTGRES_PASSWORD=netshield_pass
POSTGRES_DB=netshield_db

# FastAPI Configuration
PORT=8000
HOST=0.0.0.0
